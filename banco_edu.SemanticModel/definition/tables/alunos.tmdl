	column 'Faixa Etária' = VAR i = DATEDIFF ( [data_nascimento], TODAY (), YEAR ) RETURN SWITCH ( TRUE (), i < 20, "até 19", i < 23, "20-22", i < 26, "23-25", "26+" )
		dataType: string
		lineageTag: d618f36e-6b8c-4514-b1cb-87b7ea330c4c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition alunos = m
		mode: import
		source =
				let
				    Fonte = Odbc.Query("Driver={MySQL ODBC 9.7 Unicode Driver};Server=127.0.0.1;Port=3306;Database=banco_edu;", "SELECT aluno_id, turma_principal_id, matricula, nome, email, data_nascimento, data_ingresso, status, criado_em FROM alunos")
